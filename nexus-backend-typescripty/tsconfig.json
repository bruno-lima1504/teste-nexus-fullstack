{
  "compilerOptions": {
    "checkJs": false,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "strict": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitThis": true,
    "noUnusedParameters": true,
    "strictBindCallApply": false,
    "strictPropertyInitialization": false,
    "noFallthroughCasesInSwitch": false,
    "useDefineForClassFields": false,
    "types": [
      "node",
      "jest"
    ],
    "paths": {
      "@examModule/*": [
        "./src/module/exam/*"
      ],
      "@billingModule/*": [
        "./src/module/billing/*"
      ],
      "@identityModule/*": [
        "./src/module/identity/*"
      ],
      "@sharedModule/*": [
        "./src/module/shared/module/*"
      ],
      "@sharedLibs/*": [
        "./src/module/shared/*"
      ],
      "@src/*": [
        "./src/*"
      ],
      "@resource/*": [
        "./resource/*"
      ],
      "@testInfra/*": [
        "./test/*"
      ],
    },
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "database/**/*"
  ]
}