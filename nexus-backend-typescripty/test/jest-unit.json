{
    "moduleFileExtensions": [
        "js",
        "json",
        "ts"
    ],
    "rootDir": "..",
    "testEnvironment": "node",
    "moduleNameMapper": {
        "^@examModule/(.*)$": "<rootDir>/src/module/exam/$1",
        "^@identityModule/(.*)$": "<rootDir>/src/module/identity/$1",
        "^@sharedModule/(.*)$": "<rootDir>/src/module/shared/module/$1",
        "^@sharedLibs/(.*)$": "<rootDir>/src/module/shared/$1",
        "^(\\.{1,2}/.*)\\.js$": "$1",
        "^@src/(.*)$": "<rootDir>/src/$1",
        "^@testInfra/(.*)$": "<rootDir>/test/$1"
    },
    "transform": {
        "^.+\\.(t|j)s$": "ts-jest"
    },
    "setupFiles": [
        "<rootDir>/test/setup.ts",
        "<rootDir>/test/knex.database.ts",
        "<rootDir>/test/enum/table.enum.ts",
        "<rootDir>/test/jest-e2e.setup.ts"
    ],
    "verbose": true,
    "resetMocks": true,
    "testMatch": [
        "<rootDir>/src/**/__test__/unit/**/*.spec.ts"
    ]
}